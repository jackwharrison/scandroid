# Local development env vars for ScanDroid.
# Copy to ".env" and adjust as needed. On Azure, set these as App Settings.
#
# These were moved out of system_config.json. The loader reads them from the
# environment; the environment value always wins when set.

# Tells config_loader which path/config set to use locally
SCANDROID_ENV=local
SCANDROID_CONTEXT=local

# 121 connection (no longer editable from the System Config UI)
URL_121=https://demo.121.global
USERNAME_121=***REMOVED***
PASSWORD_121=***REMOVED***

# Secrets
ENCRYPTION_KEY=***REMOVED***

# Program display values
PROGRAM_CURRENCY=KES
PROGRAM_TITLE=Flood Response Kenya

# Optional fallbacks (only used if your code relies on them; leave unset otherwise)
# COLUMN_TO_MATCH=
# NATIONAL_SOCIETY=
